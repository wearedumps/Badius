# ─────────────────────────────────────────────
#  Configuración del Bot de Twitch + Ollama
#  Rellena cada valor y guarda el archivo
# ─────────────────────────────────────────────

# 1. Token OAuth de tu cuenta Twitch
#    Consíguelo en: https://twitchtokengenerator.com/
#    Scopes minimos para chat: chat:read y chat:edit
#    Debe empezar con "oauth:"
TWITCH_TOKEN=oauth:1nhbuyh0407tiqbngu1tvft6v14ycy

# 2. Tu nombre de usuario en Twitch (en minúsculas)
TWITCH_BOT_NICK=darigptcito

# Si usas TwitchIO v3, completa también estos 3 datos desde tu app de Twitch Dev Console.
# En TwitchIO v2 puedes dejarlos vacíos.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_ID=

# 3. Canal donde el bot va a leer y escribir (sin el #)
#    Puede ser TU propio canal o el de alguien que te dé permiso
TWITCH_CHANNEL=Baki
# ─── Ollama ───────────────────────────────────
# URL de Ollama (normalmente no hay que cambiarla)
OLLAMA_URL=http://localhost:11434

# Proveedor de IA: ollama o openrouter
IA_PROVIDER=openrouter

# OpenRouter
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_APP_NAME=bottwitch
OPENROUTER_SITE_URL=

# System prompt global (se aplica en OpenRouter y Ollama). Deja vacío para usar el prompt por defecto del código.
SYSTEM_PROMPT=
SYSTEM_PROMPT_FILE=prompts/system_prompt.txt
OWNER_USERNAME=darimary103
OWNER_SYSTEM_PROMPT_FILE=prompts/owner_system_prompt.txt

# GUI de prompts A/B (cambio en tiempo real sin reiniciar)
ENABLE_PROMPT_GUI=1
SYSTEM_PROMPT_A_FILE=prompts/system_prompt_a.txt
SYSTEM_PROMPT_B_FILE=prompts/system_prompt_b.txt
ACTIVE_PROMPT_SELECTOR_FILE=runtime/active_system_prompt.txt

# Control de modo Whisper (escuchar y responder)
WHISPER_MODE_FILE=runtime/whisper_mode_on.txt
AUTO_REPLY_MODE_FILE=runtime/auto_reply_mode_on.txt
WHISPER_LIVE_FILE=runtime/whisper_live.txt
COMMAND_QUEUE_FILE=runtime/gui_command_queue.txt
MEMORY_FILE=runtime/conversation_memory.json
# Compromiso recomendado: mas calidad de transcripcion con latencia baja.
WHISPER_MODEL=small
WHISPER_RT_MODEL=tiny
# Groq API para transcripcion Whisper (dejar vacio para usar Whisper local)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_INITIAL_PROMPT=Transcripcion en espanol neutro de una transmision en vivo de Twitch.
WHISPER_SEGUNDOS=15
WHISPER_COOLDOWN=0
WHISPER_REALTIME=1
WHISPER_RT_HOP_SEG=1
WHISPER_RT_WINDOW_SEG=3
WHISPER_CHAT_MIN_INTERVAL_SEG=10
WHISPER_MIN_TRANSCRIPCION_CHARS=4
CHANNEL_POLL_SEG=3

# Modelo a usar. Ejemplos: llama3, mistral, phi3, gemma2
# Asegúrate de tenerlo descargado: ollama pull llama3
OLLAMA_MODEL=llama3.3-8b-abliterated

# Nombre de modelo que el bot dira en chat cuando le pregunten
MODELO_PUBLICO=Llama 3.3

# ─── Comportamiento ───────────────────────────
# Segundos de espera entre preguntas por usuario (anti-spam)
COOLDOWN_SEG=10

# Limite maximo deseado para la respuesta de IA antes de mencionar al usuario
# Twitch permite hasta 500 caracteres por mensaje
MAX_RESPUESTA_CHARS=500

# ─── Velocidad de respuesta ──────────────────
# Menor num_predict = responde mas rapido (con menos detalle)
OLLAMA_NUM_PREDICT=220

# Parámetros de generación
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.90
OLLAMA_TOP_K=40
OLLAMA_MIN_P=0.05
OLLAMA_REPEAT_PENALTY=1.5
OLLAMA_REPEAT_LAST_N=64

# Timeout de respuesta de Ollama en segundos
OLLAMA_TIMEOUT_SEG=45

# Mantiene el modelo caliente en memoria para reducir latencia
OLLAMA_KEEP_ALIVE=30m

# Permite escribir comandos de Twitch desde la misma consola de bot.py
ENABLE_CONSOLE_TWITCH_CMDS=1

# ─── Panel web local ───────────────────────
# Reemplaza la GUI de escritorio por una UI HTML.
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8787
WEB_UI_AUTO_OPEN=1
